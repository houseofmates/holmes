#!/usr/bin/env python3
"""
holmes-extract — extract the inner media payload from a .holmes file.

usage:
  holmes-extract <file.holmes> [output_path]

if output_path is not given, writes to stdout (binary).
"""

import sys
import struct
import argparse
from pathlib import Path

MAGIC = b'HOLMES'


def parse(data: bytes) -> dict:
    if data[:6] != MAGIC:
        raise ValueError('not a holmes file')
    version = struct.unpack('>H', data[6:8])[0]
    mime_len = struct.unpack('>H', data[8:10])[0]
    mime_str = data[10:10 + mime_len].decode('ascii')
    payload_start = 10 + mime_len + 8
    payload_len = struct.unpack('>Q', data[10 + mime_len:payload_start])[0]
    return {
        'version': version,
        'mime_type': mime_str,
        'payload_len': payload_len,
        'payload_start': payload_start,
    }


def extract(path: str, out: str | None = None) -> dict:
    data = Path(path).read_bytes()
    header = parse(data)
    payload = data[header['payload_start']:header['payload_start'] + header['payload_len']]
    if len(payload) != header['payload_len']:
        raise ValueError(
            f"payload truncated: expected {header['payload_len']}, got {len(payload)}"
        )
    if out:
        Path(out).write_bytes(payload)
        return {**header, 'extracted_to': out}
    return {**header, 'stdout_bytes': len(payload)}


def main():
    p = argparse.ArgumentParser(description='extract media payload from a .holmes file')
    p.add_argument('holmes_file', help='.holmes file to extract from')
    p.add_argument('output', nargs='?', help='output file (default: stdout)')
    args = p.parse_args()

    result = extract(args.holmes_file, args.output)
    if args.output:
        print(f"extracted {result['payload_len']:,} bytes ({result['mime_type']}) → {args.output}")
    else:
        import sys as _sys
        _sys.stdout.buffer.write(Path(args.holmes_file).read_bytes()[result['payload_start']:result['payload_start'] + result['payload_len']])


if __name__ == '__main__':
    main()
