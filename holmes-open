#!/usr/bin/env python3
"""
holmes-open — open a .holmes file or a renamed media file.

Two modes:
  1. Real .holmes file (HOLMES magic header): parse header, extract payload
     to a temp file, and open that.
  2. Renamed media file (no HOLMES magic): detect real MIME via `file --mime-type`
     and open the original file directly.

holmes binary layout:
  offset  length  field
  0       6       magic:    "HOLMES"
  6       2       version:  uint16 big-endian (currently 1)
  8       2       mime_len: uint16 big-endian = N
  10      N       mime string (ascii)
  10+N   8       payload_len: uint64 big-endian = M
  10+N+8 M       payload (raw original media bytes)
"""
import struct
import os
import sys
import subprocess
import tempfile
import mimetypes as mime_module
import atexit
from pathlib import Path

MAGIC = b'HOLMES'
VERSION = 1

MIME_TO_EXT = {
    # images
    'image/jpeg': '.jpg', 'image/png': '.png', 'image/gif': '.gif',
    'image/webp': '.webp', 'image/bmp': '.bmp', 'image/svg+xml': '.svg',
    'image/x-icon': '.ico', 'image/tiff': '.tiff',
    # video
    'video/mp4': '.mp4', 'video/quicktime': '.mov', 'video/x-msvideo': '.avi',
    'video/x-matroska': '.mkv', 'video/webm': '.webm', 'video/x-flv': '.flv',
    'video/x-ms-wmv': '.wmv', 'video/x-m4v': '.m4v', 'video/mpeg': '.mpeg',
    'video/3gpp': '.3gp',
    # audio
    'audio/mpeg': '.mp3', 'audio/wav': '.wav', 'audio/x-m4a': '.m4a',
    'audio/mp4': '.m4a', 'audio/flac': '.flac', 'audio/ogg': '.ogg',
    'audio/aac': '.aac', 'audio/x-wma': '.wma', 'audio/x-aiff': '.aiff',
    'audio/opus': '.opus',
}

# temp files created by the HOLMES-extraction path
_temp_files: list[str] = []


def cleanup() -> None:
    for path in _temp_files:
        try:
            os.unlink(path)
        except OSError:
            pass


atexit.register(cleanup)


def launch_app(path: str) -> None:
    """Launch the default app for `path` without blocking this script."""
    subprocess.Popen(
        ['xdg-open', path],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def detect_mime_by_content(path: str) -> str:
    """Detect MIME type using `file --mime-type`, falling back to extension guess."""
    try:
        result = subprocess.run(
            ['file', '--mime-type', '-b', path],
            capture_output=True, text=True, timeout=5
        )
        mime = result.stdout.strip().splitlines()[0].strip()
        if mime and mime != 'application/octet-stream':
            return mime
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    mime, _ = mime_module.guess_type(path)
    return mime or 'application/octet-stream'


def is_media_mime(mime: str) -> bool:
    return mime.startswith('image/') or mime.startswith('video/') or mime.startswith('audio/')


def mime_to_extension(mime: str) -> str:
    if mime in MIME_TO_EXT:
        return MIME_TO_EXT[mime]
    guessed = mime_module.guess_extension(mime, strict=False)
    return guessed if guessed else '.bin'


def parse_holmes(data: bytes) -> dict:
    """Parse and validate the HOLMES binary header."""
    if len(data) < 18:
        raise ValueError('file too small to contain a holmes header (< 18 bytes)')
    if data[:6] != MAGIC:
        raise ValueError('not a holmes file (bad magic bytes)')
    version = struct.unpack('>H', data[6:8])[0]
    mime_len = struct.unpack('>H', data[8:10])[0]
    if len(data) < 10 + mime_len + 8:
        raise ValueError('file truncated')
    mime_str = data[10:10 + mime_len].decode('ascii', errors='replace')
    payload_len = struct.unpack('>Q', data[10 + mime_len:10 + mime_len + 8])[0]
    return {
        'version': version,
        'mime_type': mime_str,
        'payload_len': payload_len,
        'payload_start': 10 + mime_len + 8,
    }


def open_holmes_header(path: str) -> None:
    """Extract embedded payload from a real .holmes file and open it."""
    data = Path(path).read_bytes()
    header = parse_holmes(data)
    payload_start = header['payload_start']
    payload_len = header['payload_len']
    payload = data[payload_start:payload_start + payload_len]
    if len(payload) != payload_len:
        raise ValueError(
            f"payload truncated: expected {payload_len}, got {len(payload)}"
        )
    ext = mime_to_extension(header['mime_type'])
    tmp = tempfile.NamedTemporaryFile(suffix=ext, prefix='holmes_', delete=False)
    tmp.write(payload)
    tmp.close()
    _temp_files.append(tmp.name)
    launch_app(tmp.name)
    print(f"opened {header['mime_type']} ({payload_len:,} bytes) -> {tmp.name}")


def open_renamed_media(path: str, mime: str) -> None:
    """Open a renamed media file directly — no extraction needed."""
    launch_app(path)
    print(f"opened {mime} (renamed media) -> {path}")


def show_error(message: str) -> None:
    """Show a desktop notification and print to stderr."""
    subprocess.run(
        ['notify-send', 'holmes-open', message],
        capture_output=True, check=False
    )
    print(f"error: {message}", file=sys.stderr)


def main() -> None:
    if len(sys.argv) < 2:
        prog = os.path.basename(sys.argv[0])
        print(f"usage: {prog} <file.holmes>", file=sys.stderr)
        sys.exit(1)

    path = sys.argv[1]

    # --- fast path: check magic bytes before reading the whole file ---
    try:
        with open(path, 'rb') as fh:
            magic = fh.read(6)
    except OSError as exc:
        show_error(str(exc))
        sys.exit(1)

    if magic == MAGIC:
        # real .holmes container: extract and open
        try:
            open_holmes_header(path)
        except Exception as exc:
            show_error(str(exc))
            sys.exit(1)
    else:
        # renamed media file: detect by content and open directly
        mime = detect_mime_by_content(path)
        if is_media_mime(mime):
            open_renamed_media(path, mime)
        else:
            show_error(f"not a valid media file (detected: {mime})")
            sys.exit(1)


if __name__ == '__main__':
    main()
